# ─────────────────────────────────────────────────────────────
# CAPYABA — Variables de entorno
# Copia este archivo como .env.local y completa los valores
# ─────────────────────────────────────────────────────────────

# ── Supabase ──────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://TU_PROYECTO.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=tu_anon_key
SUPABASE_SERVICE_ROLE_KEY=tu_service_role_key

# ── Groq AI ───────────────────────────────────────────────────
GROQ_API_KEY=tu_groq_api_key

# ── App URL ───────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ─────────────────────────────────────────────────────────────
# PAYPAL — Cómo obtener las credenciales de prueba (Sandbox):
#
# 1. Ve a https://developer.paypal.com
# 2. Inicia sesión con tu cuenta PayPal normal
# 3. En el menú: Apps & Credentials → Create App
#    - Nombre: "CapyABA Dev"  |  Type: Merchant
# 4. Verás tu Client ID y Secret en modo SANDBOX
# 5. Para probar pagos usa las cuentas sandbox en:
#    https://developer.paypal.com/dashboard/accounts
#    (hay una cuenta "buyer" y una "seller" ya creadas)
# ─────────────────────────────────────────────────────────────
NEXT_PUBLIC_PAYPAL_CLIENT_ID=AX...tu_client_id_sandbox...
PAYPAL_CLIENT_SECRET=EL...tu_secret_sandbox...

# Cambia a 'production' cuando estés listo para cobros reales
PAYPAL_ENV=sandbox

# ─────────────────────────────────────────────────────────────
# CULQI — Cómo obtener las credenciales de prueba:
#
# 1. Ve a https://culqi.com y crea una cuenta (es gratis)
# 2. En el dashboard: Desarrollo → API Keys
# 3. Activa el "Modo Prueba" (switch en la esquina)
# 4. Copia la Llave Pública (pk_test_...) y la Llave Secreta (sk_test_...)
# 5. Para probar usa la tarjeta de prueba:
#    Número: 4111 1111 1111 1111
#    Fecha:  cualquier fecha futura (ej: 09/25)
#    CVV:    123
#    Nombre: cualquier nombre
# ─────────────────────────────────────────────────────────────
NEXT_PUBLIC_CULQI_PUBLIC_KEY=pk_test_tu_llave_publica
CULQI_SECRET_KEY=sk_test_tu_llave_secreta
